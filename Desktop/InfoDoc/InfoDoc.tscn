theme = ExtResource("1_pqo0r")
theme_override_fonts/bold_font = ExtResource("5_c0w7x")
bbcode_enabled = true
text = "You will never get a number below zero. If your number would be below zero, this is not a Case Two [color=red][u]dealing[/u][/color].
  "
fit_content = true

