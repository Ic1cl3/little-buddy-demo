[node name="Para1" type="RichTextLabel" parent="ScrollContainer/VBoxContainer" unique_id=1081567245]
layout_mode = 2
theme = ExtResource("1_pqo0r")
theme_override_fonts/bold_font = ExtResource("5_c0w7x")
bbcode_enabled = true
text = "We take our work here at Mango-Cookie incorperated [color=red][u]very[/u][/color] seriously. We are the top mango and cookie firm in the world as of last year. Without us, the world would struggle to deal with all its mangos and cookies. Because of that, this document is intended to help [color=royalblue][u]you[/u][/color] be a part of [color=royalblue][u]us[/u][/color], so that [color=green][u]we[/u][/color] can deal with all those mangos and cookies.
 "
fit_content = true

[node name="Para2" type="RichTextLabel" parent="ScrollContainer/VBoxContainer" unique_id=249261910]
layout_mode = 2
theme = ExtResource("1_pqo0r")
theme_override_fonts/bold_font = ExtResource("5_c0w7x")
bbcode_enabled = true
text = "You are provided with one TriangleSoft laptop with the latest version of TriangleOS installed. This laptop should have only the nessecary programs you need to do your job. This includes [color=royalblue][u]Spreadsheet[/u][/color] and [color=royalblue][u]E-mail[/u][/color] applications, the former to deal with the mangos and cookies and the latter do send your [color=red][u]dealings[/u][/color] to [color=green][u]Me[/u][/color] when you finish.
 "
fit_content = true

[node name="Para3" type="RichTextLabel" parent="ScrollContainer/VBoxContainer" unique_id=977445990]
layout_mode = 2
theme = ExtResource("1_pqo0r")
theme_override_fonts/bold_font = ExtResource("5_c0w7x")
bbcode_enabled = true
text = "Each [color=red][u]dealing[/u][/color] will consist of a pair of numbers you will see within your spreadsheet. Within every single [color=red][u]dealing[/u][/color], the [color=orange][u]first number[/u][/color] represents the number of [color=orange][u]mangos[/u][/color] and the [color=brown][u]second number[/u][/color] represents the number of [color=brown][u]cookies[/u][/color]. You will need to determine how much money each [color=red][u]dealing[/u][/color] needs. There are two different cases. 
 "
fit_content = true

[node name="Para4" type="RichTextLabel" parent="ScrollContainer/VBoxContainer" unique_id=1338009184]
layout_mode = 2
theme = ExtResource("1_pqo0r")
theme_override_fonts/bold_font = ExtResource("5_c0w7x")
bbcode_enabled = true
text = "For Case One [color=red][u]dealings[/u][/color], there will never be more be more [color=brown][u]cookies[/u][/color] than [color=orange][u]mangos[/u][/color]. The amount of money needed is the difference between the number of mangos and cookies, times 3.25. For example:
"
fit_content = true

[node name="CookieMangoDisplay2" type="Label" parent="ScrollContainer/VBoxContainer" unique_id=1574490306]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "
                = $6.50
"

