[node name="Para5" type="RichTextLabel" parent="ScrollContainer/VBoxContainer" unique_id=2075581388]
layout_mode = 2
theme = ExtResource("1_pqo0r")
theme_override_fonts/bold_font = ExtResource("5_c0w7x")
bbcode_enabled = true
text = "In the spreadsheet, this [color=red][u]dealing[/u][/color] would be represented as \"4, 2\". There are four [color=orange][u]mangos[/u][/color] and two [color=brown][u]cookies[/u][/color] here. Since 4 - 2 = 2, and 2 * 3.25 = 6.50, this [color=red][u]dealing[/u][/color] needs $6.50. 
 "
fit_content = true

[node name="Para6" type="RichTextLabel" parent="ScrollContainer/VBoxContainer" unique_id=854945359]
layout_mode = 2
theme = ExtResource("1_pqo0r")
theme_override_fonts/bold_font = ExtResource("5_c0w7x")
bbcode_enabled = true
text = "In Case Two [color=red][u]dealings[/u][/color], there will never be more be more [color=orange][u]mangos[/u][/color] than [color=brown][u]cookies[/u][/color]. The amount of money needed is the number of [color=orange][u]mangos[/u][/color] times the number of [color=brown][u]cookies[/u][/color], minus 9. For example:
"
fit_content = true

