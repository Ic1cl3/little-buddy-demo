[node name="Para7" type="RichTextLabel" parent="ScrollContainer/VBoxContainer" unique_id=391424830]
layout_mode = 2
theme = ExtResource("1_pqo0r")
theme_override_fonts/bold_font = ExtResource("5_c0w7x")
bbcode_enabled = true
text = "In the spreadsheet, this [color=red][u]dealing[/u][/color] would be represented as \"4, 6\". There are four [color=orange][u]mangos[/u][/color] and two [color=brown][u]cookies[/u][/color] here. Since 4 * 6 = 24, and 24 - 9 = 15, this [color=red][u]dealing[/u][/color] needs $15.00.
 "
fit_content = true

[node name="Para8" type="RichTextLabel" parent="ScrollContainer/VBoxContainer" unique_id=2121854591]
